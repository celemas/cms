<?php

declare(strict_types=1);

require __DIR__ . '/vendor/autoload.php';

use Celemas\Cli\Runner;
use Celemas\Cms\Commands\RecreateDb;
use Celemas\Cms\Config;
use Celemas\Cms\MigrationFactory;
use Celemas\Container\Container;
use Celemas\Quma\Commands as QumaCommands;
use Celemas\Quma\Connection;

$container = new Container();
$container->add(Config::class, new Config(__DIR__));

$conn = new Connection(
	'pgsql:host=localhost;dbname=celemas;user=celemas;password=celemas',
	__DIR__ . '/db/sql',
)
	->migrations(__DIR__ . '/db/migrations/install')
	->fetch(PDO::FETCH_ASSOC);

$commands = QumaCommands::get($conn, migrationFactory: new MigrationFactory($container));
$commands->add(new RecreateDb('celemas', 'celemas', 'celemas'));

$runner = new Runner($commands);

exit($runner->run());

// vim: ft=php
